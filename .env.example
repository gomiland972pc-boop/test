# Токен бота МАКС (получить на https://business.max.ru/self -> Чат-боты -> Интеграция)
MAX_BOT_TOKEN=your_token_here

# Список user_id администраторов через запятую
ADMIN_IDS=6228168

# Путь к файлу SQLite
DB_PATH=bot.db

# Базовый URL API МАКС
MAX_API_BASE=https://botapi.max.ru

# URL webhook-подписки, если раньше использовался webhook
WEBHOOK_URL=
