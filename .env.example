# --- Обязательные ---

# Токен бота, выдаётся @MasterBot в МАКС при создании бота
MAX_BOT_TOKEN=

# Список ID администраторов через запятую (числовые user_id в МАКС)
ADMIN_IDS=

# Публичный HTTPS-адрес, на который МАКС шлёт обновления.
#
# ВНИМАНИЕ: это адрес ВАШЕГО сервера, а НЕ адрес МАКС.
#
# Локальный тест: нужен HTTPS-туннель к локальному порту 8080.
#   1) Установить cloudflared: https://github.com/cloudflare/cloudflared/releases
#   2) Запустить: cloudflared tunnel --url http://localhost:8080
#   3) Подставить выданный адрес + /webhook в конце:
#      WEBHOOK_URL=https://xxxx-yyyy.trycloudflare.com/webhook
#
# Bot-host.ru: WEBHOOK_URL подставляется автоматически после деплоя
# (https://<поддомен>.bothost.tech/webhook). Этот .env при деплое
# не используется — переменные задаются в форме бота на Bot-host.
WEBHOOK_URL=


# --- Опциональные (можно оставить по умолчанию) ---

# Путь к файлу SQLite (создастся автоматически)
DB_PATH=bot.db

# Базовый URL Bot API МАКС
MAX_API_BASE=https://botapi.max.ru

# Секрет для проверки заголовка X-Max-Bot-Api-Secret от МАКС
# 5..256 символов: a-z A-Z 0-9 _ -
# Сгенерировать: python -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters+string.digits+'_-') for _ in range(48)))"
WEBHOOK_SECRET=

# Путь, по которому aiohttp-сервер принимает webhook'и
WEBHOOK_PATH=/webhook

# Локальный адрес и порт, на которых поднимается aiohttp-сервер
# (за reverse-proxy типа nginx/caddy с TLS).
# На Bot-host порт задаётся платформой через env-переменную PORT
# и подхватывается автоматически.
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
